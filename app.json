{
  "expo": {
    "name": "zupet",
    "slug": "pet_agenda",
    "version": "1.15.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zupet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Usado para tirar foto do seu pet ou do seu perfil.",
        "NSPhotoLibraryUsageDescription": "Usado para escolher uma foto da galeria para o seu pet ou perfil.",
        "NSPhotoLibraryAddUsageDescription": "Usado para salvar fotos do app na galeria."
      }
    },
    "android": {
      "package": "io.zupet.app",
      "versionCode": 160,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Usado para escolher uma foto da galeria para o seu pet ou perfil.",
          "cameraPermission": "Usado para tirar foto do seu pet ou do seu perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#40E0D0",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4896814460874070~9642369147",
          "iosAppId": "ca-app-pub-4896814460874070~9642369147",
          "userTrackingUsageDescription": "Esse identificador será usado para exibir anúncios personalizados para você.",
          "skAdNetworkItems": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89b056d3-a79b-4c93-a26b-cbff4afe007a"
      },
      "privacyPolicyUrl": "https://zupet.io/privacidade",
      "termsOfServiceUrl": "https://zupet.io/termos"
    },
    "owner": "eduallochio"
  }
}
